# Carregando as bibliotecas principais
library(tidyverse)
# Lendo os dados brutos
df_turismo <- read.csv("Tourism Quality/Tourism Quality Data.csv")
# Ajuste inicial de tipos de dados
df_turismo <- df_turismo %>%
mutate(
Ano = as.factor(Ano), # Transformando o Ano em fator (categoria)
IncomeGroup = factor(IncomeGroup,
levels = c("Low income", "Lower middle income",
"Upper middle income", "High income")) # Ordenando a renda
)
# Visualização inicial da base final
glimpse(df_turismo)
unique(df_turismo$Ano)
df_turismo %>%
group_by(Region) %>%
summarise(
cultural_demand = mean(Cultural.Demand, na.rm = TRUE),
natural_demand = mean(Natural.Demand, na.rm = TRUE),
gdp = mean(T.T.Industry.GDP, na.rm = TRUE)
) %>%
pivot_longer(-Region) %>%
ggplot(aes(x = Region, y = value, fill = name)) +
geom_col(position = "dodge") +
coord_flip()
View(df_turismo)
View(df_turismo)
