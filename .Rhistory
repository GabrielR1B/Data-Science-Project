medias <- df_turismo %>%
group_by(Region, Ano) %>%
summarise(
cultural_demand = mean(Cultural.Demand, na.rm = TRUE),
natural_demand = mean(Natural.Demand, na.rm = TRUE),
gdp = mean(T.T.industry.GDP, na.rm = TRUE)) %>%
pivot_longer(-c(Region,Ano))
ggplot(medias) +
aes(x = Region, y = value, fill = Ano) +
geom_col() +
scale_fill_hue(direction = 1) +
theme_minimal()
